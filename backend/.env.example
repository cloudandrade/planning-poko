# Legado / modo standalone (`cd backend && npm run dev`)
# Recomendado: use apenas o `.env` na RAIZ do repositório (mesmas chaves).
# Ordem de carga em `backend/src/index.js`: ../../.env depois ../.env

PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=planning-poko
RESET_DB=false
CLEAR_DB_TABLES=false
