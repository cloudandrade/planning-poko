# Copie para .env na raiz:  cp .env.example .env  (ou renomeie manualmente)
# Toda a stack (Next + Express + Socket.io + Mongo) lê a partir da raiz via server.cjs.

# Servidor unificado
PORT=3000
NODE_ENV=development

# MongoDB (local)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=planning-poko

# Manutenção do banco (use com cuidado)
# RESET_DB=true        → dropDatabase no DB configurado
# CLEAR_DB_TABLES=true → apaga documentos das coleções (mantém índices)
RESET_DB=false
CLEAR_DB_TABLES=false
